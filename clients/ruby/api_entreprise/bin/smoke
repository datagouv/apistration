#!/usr/bin/env ruby
# frozen_string_literal: true
#
# Manual release-time smoke check against staging. Not run in CI.
#
#   TOKEN=$(curl -s https://raw.githubusercontent.com/datagouv/apistration/develop/mocks/tokens/default)
#   API_ENTREPRISE_TOKEN=$TOKEN bin/smoke

$LOAD_PATH.unshift File.expand_path('../lib', __dir__)
require 'api_entreprise'

client = ApiEntreprise::Client.new(
  environment: :staging,
  default_params: {
    recipient: '13002526500013',
    context:   'Smoke test',
    object:    'Release verification'
  }
)

response = client.insee.unites_legales('418166096')
puts "status=#{response.http_status} remaining=#{response.rate_limit&.remaining} keys=#{response.data&.keys&.first(5).inspect}"
