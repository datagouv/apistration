            "intitule": {
              "value": "Développement du football féminin dans les établissements scolaires",
              "provider": "OSIRIS",
              "last_update": "2019-01-01T00:00:00.000Z",
              "type": "string"
            },
            "objectifs": {
              "value": "Promouvoir la pratique du football féminin auprès des jeunes filles de 8 à 16 ans dans les écoles primaires et collèges du territoire. Organiser des tournois inter-établissements et former des équipes compétitives.",
              "provider": "OSIRIS",
              "last_update": "2019-01-01T00:00:00.000Z",
              "type": "string"
            },
            "objectifs_operationnels": {
              "value": "Développement de la pratique",
              "provider": "OSIRIS",
              "last_update": "2019-01-01T00:00:00.000Z",
              "type": "string"
            },
            "description": {
              "value": "Le projet consiste à intervenir dans 8 établissements scolaires du territoire avec des séances d'initiation et de perfectionnement au football féminin. Chaque établissement bénéficiera de 10 séances de 2 heures, encadrées par notre éducatrice diplômée. Le matériel pédagogique (ballons, cônes, chasubles) sera fourni par le club.",
              "provider": "OSIRIS",
              "last_update": "2019-01-01T00:00:00.000Z",
              "type": "string"
            },
            "nature_aide": {
              "value": "Projets sportifs territoriaux",
