require 'swagger_helper'

RSpec.describe '<%= provider_namespace %>: <%= resource_class.humanize %> With FranceConnect', api: :<%= api %>, type: %i[request swagger] do
  path '/v3/<%= provider_namespace.underscore %>/<%= resource_class.underscore.pluralize %>/france_connect' do
    get "[FranceConnect] #{SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.title')}" do
      tags(*SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.tags'))

      common_action_attributes

      let(:recipient) { valid_siret(:recipient) }
      let(:Authorization) { 'Bearer super_valid_token' }

      forbidden_france_connect_request

      let(:scopes) { %i[<%= provider_namespace.underscore.gsub('/', '_') %>_<%= resource_class.underscore %>] }

      describe 'with a FranceConnect token' do
        before do
          mock_valid_france_connect_checktoken(scopes:)
        end

        <% unless prochainement? -%>
        describe 'when identite is found' do
          before do
            stub_<%= provider_namespace.underscore.gsub('/', '_') %>_<%= resource_class.underscore %>_valid
          end

          response '200', 'Identité trouvée' do
            description SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.description')

            rate_limit_headers

            schema build_rswag_response(
              attributes: SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.attributes')
            )

            run_test!
          end
        end

        describe 'when identite is not found' do
          before do
            stub_<%= provider_namespace.underscore.gsub('/', '_') %>_<%= resource_class.underscore %>_not_found
          end

          response '404', 'Non trouvée' do
            build_rswag_example(NotFoundError.new('<%= provider_namespace %>'))

            schema '$ref' => '#/components/schemas/Error'

            run_test!
          end
        end
        <% else -%>
        response '200', 'Identité trouvée', pending: 'Implement endpoint' do
          before do
            allow(MockDataBackend).to receive(:get_response_for).and_return(nil)
          end
          description SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.description')

          rate_limit_headers

          schema build_rswag_response(
            attributes: SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.attributes')
          )

          run_test!
        end
        <% end -%>
      end
    end
  end
end
