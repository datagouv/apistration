require 'swagger_helper'

RSpec.describe '<%= provider_namespace %>: <%= resource_class.humanize %>', type: %i[request swagger] do
  path '/v3/<%= provider_namespace.underscore %>/<%= resource_class.underscore.pluralize %>/{<%= id_path_param %>}' do
    get SwaggerInformation.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.title') do
      tags(*SwaggerInformation.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.tags'))

      common_action_attributes

      parameter name: :<%= id_path_param %>, in: :path, type: :string

      unauthorized_request do
        let(:<%= id_path_param %>) { valid_<%= id_path_param %>(:<%= provider_namespace.underscore %>) }
      end

      forbidden_request do
        let(:<%= id_path_param %>) { valid_<%= id_path_param %>(:<%= provider_namespace.underscore %>) }
      end

      describe 'with valid mandatory params', valid: true do
        response '200', 'Entreprise trouvée', vcr: { cassette_name: '<%= provider_namespace.underscore %>/valid_<%= id_path_param %>_json' } do
          description SwaggerInformation.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.description')

          rate_limit_headers

          schema build_rswag_response(
            id: valid_<%= id_path_param %>(:<%= provider_namespace.underscore %>),
            type: 'entreprise',
            attributes: SwaggerInformation.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.attributes')
          )

          run_test!
        end

        response '404', 'Non trouvée', vcr: { cassette_name: '<%= provider_namespace.underscore %>/not_found_<%= id_path_param %>' } do
          let(:<%= id_path_param %>) { not_found_<%= id_path_param %>(:<%= provider_namespace.underscore %>) }

          schema '$ref' => '#/components/schemas/NotFound'

          run_test!
        end
      end
    end
  end
end

