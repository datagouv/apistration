require 'swagger_helper'

RSpec.describe '<%= provider_namespace %>: <%= resource_class.humanize %>', type: %i[request swagger], api: :<%= api %> do
  path '/v3/<%= provider_namespace.underscore %>/<%= resource_class.underscore.pluralize %>/{<%= id_path_param %>}' do
    get SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.title') do
      tags(*SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.tags'))

      common_action_attributes

      parameter name: :<%= id_path_param %>, in: :path, type: :string

      unauthorized_request do
        let(:<%= id_path_param %>) { valid_<%= id_path_param %>(:<%= provider_namespace.underscore %>) }
      end

      forbidden_request do
        let(:<%= id_path_param %>) { valid_<%= id_path_param %>(:<%= provider_namespace.underscore %>) }
      end

      too_many_requests(<%= name %>) do
        let(:<%= id_path_param %>) { valid_<%= id_path_param %>(:<%= provider_namespace.underscore %>) }
      end

      describe 'with valid token and mandatory params', valid: true do
        response '200', 'Entreprise trouvée'<% unless prochainement? %>, vcr: { cassette_name: '<%= provider_namespace.underscore %>/valid_<%= id_path_param %>' }<% end %> do
          <% if prochainement? %>before do
              allow(MockDataBackend).to receive(:get_response_for).and_return(nil)
          end
          <% end %>
          description SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.description')

          rate_limit_headers

          schema build_rswag_response(
            id: valid_<%= id_path_param %>(:<%= provider_namespace.underscore %>),
            type: '<%= api == "entreprise" ? "entreprise" : "resource" %>',
            attributes: SwaggerData.get('<%= provider_namespace.underscore %>.<%= resource_class.underscore %>.attributes')
          )

          run_test!
        end

        describe 'server errors' do
          let(:<%= id_path_param %>) { valid_<%= id_path_param %>(:<%= provider_namespace.underscore %>) }

          unprocessable_entity_error_request(:<%= id_path_param %>) do
            let(:<%= id_path_param %>) { 'lol' }
          end

          response '404', 'Non trouvée', vcr: { cassette_name: '<%= provider_namespace.underscore %>/not_found_<%= id_path_param %>' }<%= prochainement? ? ", pending: 'Implement endpoint'" : nil %> do
            let(:<%= id_path_param %>) { not_found_<%= id_path_param %>(:<%= provider_namespace.underscore %>) }

            build_rswag_example(NotFoundError.new('<%= provider_namespace %>'))

            schema '$ref' => '#/components/schemas/Error'

            run_test!
          end

          <% if document_resource? %>
          common_provider_errors_request(
            '<%= provider_namespace %>',
            <%= name %>,
            documents_errors('<%= provider_namespace %>')
          )
        <% else %>
          common_provider_errors_request('<%= provider_namespace %>', <%= name %>)
        <% end %>
          common_network_error_request('<%= provider_namespace %>', <%= name %>)
        end
      end
    end
  end
end

