class API::V3AndMore::<%= name %>Controller < API::V3AndMore::BaseController
  def show
    authorize :<%= resource_class.underscore %>

    organizer = ::<%= name %>.call(params: organizer_params)

    if organizer.success?
      render json: serializer_class.new(organizer.resource).serializable_hash,
        status: extract_http_code(organizer)
    else
      render_errors(organizer)
    end
  end

  private

  def organizer_params
    fail NotImplementedError
  end

  def serializer_module
    ::<%= provider_namespace %>::<%= resource_class %>Serializer
  end
end
