class API<%= api.classify %>::V3AndMore::<%= provider_namespace %>::<%= resource_class %>Controller < API<%= api.classify %>::V3AndMore::BaseController
  def show
    if organizer.success?
<% if prochainement? -%>
      render json: organizer[:payload],
        status: organizer[:status]
<% else -%>
      render json: serialize_data,
        status: extract_http_code(organizer)
<% end -%>
    else
      render_errors(organizer)
    end
  end

  private

  def organizer_params
    fail NotImplementedError
  end

  def serializer_module
    ::API<%= api.classify %>::<%= provider_namespace %>::<%= resource_class %>Serializer
  end

  def organizer
    @organizer ||= retrieve_payload_data(::<%= name %>)
  end
end
