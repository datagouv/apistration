class API<%= api.classify %>::V3AndMore::<%= name %>Controller < API<%= api.classify %>::V3AndMore::BaseController
  def show
    if organizer.success?
      <% if prochainement? %>
      render json: organizer[:payload],
        status: organizer[:status]
      <% else %>
      render json: serialize_data,
        status: extract_http_code(organizer)
    <% end %>
    else
      render_errors
    end
  end

  private

  def organizer_params
<% if options[:validation_type]&.downcase == 'civility' %>
    params.permit(
      :nom_naissance,
      :prenoms,
      :sexe,
      :date_naissance,
      :code_cog_insee_commune_naissance,
      :code_cog_insee_pays_naissance
    )
<% else %>
    fail NotImplementedError
<% end %>
  end

  def serializer_module
    ::API<%= api.classify %>::<%= provider_namespace %>::<%= resource_class %>Serializer
  end

  def organizer
    @organizer ||= retrieve_payload_data(::<%= name %>)
  end
end
