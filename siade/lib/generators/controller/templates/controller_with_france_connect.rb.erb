class API<%= api.classify %>::V3AndMore::<%= provider_namespace %>::<%= resource_class %>WithFranceConnectController < API<%= api.classify %>::V3AndMore::BaseController
  include API<%= api.classify %>::FranceConnectable
  include API<%= api.classify %>::CivilityParameters

  def show
    if organizer.success?
      render json: serialize_data,
        status: extract_http_code(organizer)
    else
      render_errors(organizer)
    end
  end

  private

  def organizer_params
    civility_parameters_from_france_connect
  end

  def serializer_module
    ::API<%= api.classify %>::<%= provider_namespace %>::<%= resource_class %>Serializer
  end

  def organizer
    @organizer ||= retrieve_payload_data(::<%= name %>)
  end
end
