class <%= name %>::MakeRequest < <%= prochainement? ? 'MockedInteractor' : "MakeRequest::#{get_request? ? 'Get' : 'Post'}" %>
  protected

  def mocking_params
    # XXX You should remove request params which are not provided by the user
    # If you don't have to remove any params, you can remove this method
    # Params here must be downcased because github returns downcased params when fetching payloads from siade_staging_data
<% if api_particulier? && civility_validation? -%>
    {
      nomNaissance: context.params[:nom_naissance]&.downcase,
      nomUsage: context.params[:nom_usage]&.downcase,
      prenoms: context.params[:prenoms]&.map(&:downcase),
      anneeDateNaissance: context.params[:annee_date_naissance]&.to_i,
      moisDateNaissance: context.params[:mois_date_naissance]&.to_i,
      jourDateNaissance: context.params[:jour_date_naissance]&.to_i,
      sexeEtatCivil: context.params[:sexe_etat_civil]&.downcase,
      codeCogInseePaysNaissance: context.params[:code_cog_insee_pays_naissance],
      codeCogInseeCommuneNaissance: context.params[:code_cog_insee_commune_naissance]
    }.compact
<% end -%>
  end

  def request_uri
    fail NotImplementedError
  end

  def request_params
    fail NotImplementedError
  end

  private

  def <%= provider_namespace.underscore %>_domain
    Siade.credentials[:<%= provider_namespace.underscore %>_domain]
  end
end
