RSpec.describe <%= name %>::BuildResourceCollection, type: :build_resource do
  subject { described_class.call(response: response) }

  let(:response) { instance_double('Net::HTTPOK', body: body) }

  let(:body) do
    <%= name %>::MakeRequest.call(params: params).response.body
  end<% if id_name %>

  let(:params) do
    {
      <%= id_name %>: <%= id_name %>
    }
  end<% end %>

  let(:valid_collection) do
    []
  end

  it { is_expected.to be_a_success }

  it 'builds valid resources' do
    expect(call.resource_collection).to all be_a(Resource)
  end

  it 'has valid resource_collection' do
    expect(call.resource_collection.map(&:to_h)).to eq(valid_collection)
  end
end
