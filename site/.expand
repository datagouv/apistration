# Each line is "source:destination" where source is relative to the repository
# root and destination is relative to this app's build directory. The deploy
# script replaces the destination path with a real copy of source at deploy
# time. Lines starting with '#' and blank lines are ignored. When destination
# is omitted, source is used for both.
commons/swagger/openapi-entreprise.yaml:config/api-entreprise-v3-openapi.yml
commons/swagger/openapi-particulier.yaml:config/api-particulier-openapi-v3.yml
commons/swagger/api_particulier_open_api_static/v2.yaml:config/api-particulier-openapi.yml
commons/data/throttle.yml:config/throttle.yml
commons/endpoints/api_entreprise:config/endpoints/api_entreprise
commons/endpoints/api_particulier:config/endpoints/api_particulier
commons/endpoints/template.entreprise.yml.example:config/endpoints/template.entreprise.yml.example
commons/endpoints/template.particulier.yml.example:config/endpoints/template.particulier.yml.example
